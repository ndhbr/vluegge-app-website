---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Impressum – vluegge" description="Impressum der vluegge UG (haftungsbeschränkt)">
  <Header />
  <main id="main-content" class="section-padding">
    <div class="container-main max-w-3xl">
      <h1 class="mb-10 text-3xl font-bold text-navy md:text-4xl">Impressum</h1>

      <div class="space-y-8 text-base leading-relaxed text-text-main">
        <section>
          <h2 class="mb-2 text-lg font-bold text-navy">Angaben gemäß § 5 DDG</h2>
          <p>
            vluegge UG (haftungsbeschränkt)<br />
            Haferkamp 3<br />
            49586 Merzen<br />
            Deutschland
          </p>
        </section>

        <section>
          <h2 class="mb-2 text-lg font-bold text-navy">Vertreten durch den Geschäftsführer</h2>
          <p>Frederik Abing</p>
        </section>

        <section>
          <h2 class="mb-2 text-lg font-bold text-navy">Kontakt</h2>
          <p>
            E-Mail: <a href="mailto:hello@vluegge.com" class="text-primary transition-colors hover:text-primary/80">hello@vluegge.com</a>
          </p>
        </section>

        <section>
          <h2 class="mb-2 text-lg font-bold text-navy">Handelsregister</h2>
          <p>
            Eingetragen im Handelsregister des Amtsgerichts Osnabrück<br />
            Handelsregisternummer: HRB 222694
          </p>
        </section>

        <section>
          <h2 class="mb-2 text-lg font-bold text-navy">Umsatzsteuer-ID</h2>
          <p>
            Umsatzsteuer-Identifikationsnummer gemäß § 27a UStG:<br />
            DE461292228
          </p>
        </section>

        <section>
          <h2 class="mb-2 text-lg font-bold text-navy">Technische Umsetzung</h2>
          <p>
            <a href="https://bavarianbits.de" target="_blank" rel="noopener noreferrer" class="text-primary transition-colors hover:text-primary/80">BavarianBits GmbH</a>
          </p>
        </section>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
