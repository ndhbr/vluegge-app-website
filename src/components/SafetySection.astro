<section id="sicherheit" class="section-padding bg-gradient-to-br from-light-blue/50 via-white to-light-purple/30" aria-labelledby="safety-heading">
  <div class="container-main">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Left Content -->
      <div class="reveal">
        <h2 id="safety-heading" class="mb-6 text-3xl font-bold leading-tight text-navy md:text-4xl">
          Digitale Begegnungen – echt und sicher
        </h2>
        <p class="mb-8 text-lg leading-relaxed text-text-main">
          Bei vluegge stehen Sicherheit, Vertrauen und Verantwortung im Mittelpunkt. Es geht nicht um anonyme Kontakte, sondern um echte Menschen in einem begleiteten Rahmen.
        </p>

        <ul class="grid gap-3 sm:grid-cols-2" role="list">
          {[
            'Verifizierte Nutzer',
            'Kein Fake-Profil',
            'Kein anonymer Raum',
            'Respektvolle Interaktion',
            'Guardian begleitet',
            'Sicherer Kommunikationsraum',
          ].map((item) => (
            <li class="flex items-center gap-2.5 rounded-xl border border-medium-grey/40 bg-white px-4 py-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="shrink-0" aria-hidden="true">
                <path d="M20 6L9 17l-5-5" stroke="#155DFC" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-sm font-medium text-navy">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- HGCO Card -->
      <div class="reveal reveal-delay-2 rounded-card border-2 border-primary/20 bg-white p-8 md:p-10 transition-all duration-300 hover:shadow-card-hover">
        <div class="mb-5 inline-flex items-center gap-3">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-light-blue">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="#155DFC" stroke-width="2" stroke-linecap="round"/>
              <path d="M9 12l2 2 4-4" stroke="#9810FA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
        <h3 class="mb-1 text-2xl font-bold text-navy">HGCO</h3>
        <p class="mb-4 text-base font-semibold text-primary">Human Governed Content Only</p>
        <p class="mb-6 text-base leading-relaxed text-text-main">
          Ein digitaler Raum, in dem soziale Interaktionen unter menschlicher Verantwortung stattfinden.
        </p>
        <p class="mb-5 text-lg font-bold text-navy">
          Echte Menschen. Echte Begegnungen.
        </p>
        <span class="inline-block rounded-full border border-purple/30 bg-light-purple px-4 py-1.5 text-sm font-medium text-purple">
          KI unterstützt – Menschen entscheiden.
        </span>
      </div>
    </div>
  </div>
</section>
