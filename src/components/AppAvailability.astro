---
import PhoneMockup from './PhoneMockup.astro';
---

<section id="app" class="section-padding bg-gradient-to-br from-light-blue via-white to-light-purple/50" aria-labelledby="app-heading">
  <div class="container-main">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Text -->
      <div class="reveal">
        <h2 id="app-heading" class="mb-6 text-3xl font-bold leading-tight text-navy md:text-4xl">
          Die vluegge App startet bald.
        </h2>
        <p class="mb-4 text-lg leading-relaxed text-text-main">
          Wir bereiten aktuell den Start vor. Sobald vluegge verfügbar ist, findest du hier die Download-Links für iOS und Android.
        </p>
        <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-light-blue px-4 py-2 text-sm font-semibold text-primary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          Launch: Sommer 2026
        </div>

        <!-- Store Buttons -->
        <div class="mb-8 grid grid-cols-2 gap-4">
          <!-- App Store -->
          <button type="button" aria-disabled="true" class="inline-flex items-center gap-2.5 rounded-2xl border-2 border-medium-grey/60 bg-light-grey px-4 py-3 cursor-not-allowed" tabindex="-1">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0">
              <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" fill="#9CA3AF"/>
            </svg>
            <span class="text-left">
              <span class="block text-[10px] leading-none text-text-main/60">Laden im</span>
              <span class="block text-sm font-bold leading-tight text-text-main/70">App Store</span>
            </span>
          </button>

          <!-- Google Play -->
          <button type="button" aria-disabled="true" class="inline-flex items-center gap-2.5 rounded-2xl border-2 border-medium-grey/60 bg-light-grey px-4 py-3 cursor-not-allowed" tabindex="-1">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="shrink-0">
              <path d="M3.5 20.5V3.5c0-.85.46-1.27 1-1.5l9.5 9.5-9.5 9.5c-.54-.23-1-.65-1-1.5z" fill="#9CA3AF"/>
              <path d="M15 12l3.5-2-3.5-2" fill="#9CA3AF"/>
              <path d="M4.5 2l11 6.5L14 10 4.5 2zM4.5 22l11-6.5L14 14 4.5 22z" fill="#9CA3AF"/>
            </svg>
            <span class="text-left">
              <span class="block text-[10px] leading-none text-text-main/60">Jetzt bei</span>
              <span class="block text-sm font-bold leading-tight text-text-main/70">Google Play</span>
            </span>
          </button>
        </div>

        <p class="text-base text-text-main">
          Für Familien, Guardians und Einrichtungen in Vorbereitung.
        </p>
      </div>

      <!-- Phone Mockup -->
      <div class="reveal reveal-delay-2 flex justify-center">
        <PhoneMockup screenshot="/assets/images/vluegge-app-screen-4.webp" />
      </div>
    </div>
  </div>
</section>
