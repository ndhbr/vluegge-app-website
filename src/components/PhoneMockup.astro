---
interface Props {
  class?: string;
  screenshot?: string;
}

const { class: className = '', screenshot } = Astro.props;
---

<div class:list={['relative mx-auto w-[280px]', className]}>
  <!-- Phone frame -->
  <div class="rounded-[40px] border-[8px] border-navy/90 bg-white p-1 shadow-xl">
    <!-- Notch -->
    <div class="absolute left-1/2 top-3 h-5 w-20 -translate-x-1/2 rounded-full bg-navy/90"></div>
    <!-- Screen: aspect ratio matches 768x1704 screenshots to prevent layout shift -->
    <div class="overflow-hidden rounded-[32px] bg-white" style="aspect-ratio: 768/1704;">
      {screenshot ? (
        <img src={screenshot} alt="vluegge App Vorschau" class="h-full w-full object-cover" loading="lazy" width="768" height="1704" />
      ) : (
        <div class="flex min-h-[586px] flex-col px-4 pt-10 pb-3">
          <!-- App Header -->
          <div class="mb-1 px-1">
            <p class="text-[15px] font-bold text-navy">Vorschläge</p>
            <p class="text-[10px] text-text-main">Menschen, die gut zu dir passen</p>
          </div>

          <!-- Profile Card 1 -->
          <div class="mt-3 rounded-2xl border border-medium-grey/60 p-3">
            <!-- Profile image placeholder -->
            <div class="mb-2 h-28 w-full rounded-xl bg-gradient-to-br from-light-blue to-light-purple"></div>
            <p class="text-center text-[15px] font-bold text-navy">Anna</p>
            <!-- Interest tags -->
            <div class="mt-1.5 flex justify-center gap-1.5">
              <span class="rounded-full bg-[#FDE8F0] px-2.5 py-0.5 text-[9px] font-semibold text-danger">Musik</span>
              <span class="rounded-full bg-light-purple px-2.5 py-0.5 text-[9px] font-semibold text-purple">Kunst</span>
              <span class="rounded-full bg-[#DCFCE7] px-2.5 py-0.5 text-[9px] font-semibold text-success">Spazieren</span>
            </div>
            <!-- Action button -->
            <button class="mt-2.5 w-full rounded-xl bg-primary py-2 text-center text-[10px] font-semibold text-white" aria-hidden="true" tabindex="-1">
              Anna ansehen
            </button>
          </div>

          <!-- Profile Card 2 (partial) -->
          <div class="mt-2.5 rounded-2xl border border-medium-grey/60 p-3">
            <div class="mb-2 h-16 w-full rounded-xl bg-gradient-to-br from-light-purple/60 to-light-blue/60"></div>
            <p class="text-center text-[15px] font-bold text-navy">Max</p>
            <div class="mt-1.5 flex justify-center gap-1.5">
              <span class="rounded-full bg-light-blue px-2.5 py-0.5 text-[9px] font-semibold text-primary">Filme</span>
              <span class="rounded-full bg-[#FEF9C3] px-2.5 py-0.5 text-[9px] font-semibold text-[#A16207]">Kochen</span>
            </div>
          </div>

          <!-- Bottom Navigation -->
          <div class="mt-auto flex items-center justify-around border-t border-medium-grey/40 pt-2.5">
            <div class="flex flex-col items-center gap-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="#155DFC" stroke-width="2.5" stroke-linecap="round"/></svg>
              <span class="text-[8px] font-semibold text-primary">Start</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#9CA3AF" stroke-width="2"/></svg>
              <span class="text-[8px] text-text-main/60">Freunde</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" stroke="#9CA3AF" stroke-width="2"/><path d="M16 2v4M8 2v4M3 10h18" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"/></svg>
              <span class="text-[8px] text-text-main/60">Termine</span>
            </div>
            <div class="flex flex-col items-center gap-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="5" stroke="#9CA3AF" stroke-width="2"/><path d="M20 21a8 8 0 10-16 0" stroke="#9CA3AF" stroke-width="2" stroke-linecap="round"/></svg>
              <span class="text-[8px] text-text-main/60">Profil</span>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>
</div>
