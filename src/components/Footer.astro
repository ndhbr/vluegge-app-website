---
import Logo from './Logo.astro';
---

<footer class="bg-navy py-12 md:py-16">
  <div class="container-main">
    <div class="flex flex-col items-center text-center md:flex-row md:items-start md:justify-between md:text-left">
      <!-- Brand -->
      <div class="mb-8 md:mb-0">
        <Logo class="mb-3 brightness-0 invert" />
        <p class="max-w-xs text-sm text-white/60">
          Digitale Begegnungen – sicher begleitet.
        </p>
      </div>

      <!-- Navigation -->
      <nav aria-label="Footer Navigation">
        <ul class="flex flex-wrap justify-center gap-x-8 gap-y-3 text-sm">
          <li><a href="/impressum" class="text-white/70 transition-colors hover:text-white focus-ring rounded-lg">Impressum</a></li>
          <li><a href="/datenschutz" class="text-white/70 transition-colors hover:text-white focus-ring rounded-lg">Datenschutz</a></li>
        </ul>
      </nav>
    </div>

    <!-- Divider & Copyright -->
    <div class="mt-10 border-t border-white/10 pt-6 text-center">
      <p class="text-xs text-white/40">
        &copy; 2026 vluegge UG (haftungsbeschr&auml;nkt). Alle Rechte vorbehalten.
      </p>
    </div>
  </div>
</footer>
