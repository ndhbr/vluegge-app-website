---
const audiences = [
  {
    icon: 'home',
    title: 'Familien',
    text: 'Ein sicherer Rahmen, in dem eure Liebsten neue Kontakte knüpfen können.',
    accent: 'border-primary/30 bg-light-blue/30',
    iconBg: 'bg-light-blue',
    iconColor: '#155DFC',
  },
  {
    icon: 'building',
    title: 'Wohneinrichtungen',
    text: 'Soziale Teilhabe strukturiert und begleitet ermöglichen.',
    accent: 'border-purple/30 bg-light-purple/30',
    iconBg: 'bg-light-purple',
    iconColor: '#9810FA',
  },
  {
    icon: 'briefcase',
    title: 'Betreuer & Assistenz',
    text: 'Mehr Sicherheit, Überblick und klare Prozesse im Alltag.',
    accent: 'border-primary/30 bg-light-blue/30',
    iconBg: 'bg-light-blue',
    iconColor: '#155DFC',
  },
  {
    icon: 'star',
    title: 'Menschen mit Unterstützungsbedarf',
    text: 'Mehr Selbstständigkeit, Kontakte und Teilhabe.',
    accent: 'border-purple/30 bg-light-purple/30',
    iconBg: 'bg-light-purple',
    iconColor: '#9810FA',
  },
];

const icons: Record<string, string> = {
  home: '<path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
  building: '<rect x="4" y="2" width="16" height="20" rx="2" stroke="currentColor" stroke-width="2"/><path d="M9 6h2M13 6h2M9 10h2M13 10h2M9 14h2M13 14h2M9 18h6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  briefcase: '<rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>',
  star: '<path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>',
};
---

<section id="fuer-wen" class="section-padding bg-[#F8FAFC]" aria-labelledby="audience-heading">
  <div class="container-main">
    <div class="reveal mb-14 text-center">
      <h2 id="audience-heading" class="mb-3 text-3xl font-bold text-navy md:text-4xl">Für wen ist vluegge?</h2>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {audiences.map((item, i) => (
        <div class:list={[`reveal reveal-delay-${i + 1} group rounded-card border-2 bg-white p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-card-hover`, item.accent]}>
          <div class:list={['mb-5 flex h-12 w-12 items-center justify-center rounded-2xl transition-transform duration-300 group-hover:scale-110', item.iconBg]}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true" style={`color: ${item.iconColor}`} set:html={icons[item.icon]} />
          </div>
          <h3 class="mb-2 text-lg font-bold text-navy [hyphens:auto]" lang="de">{item.title}</h3>
          <p class="text-base leading-relaxed text-text-main">{item.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>
