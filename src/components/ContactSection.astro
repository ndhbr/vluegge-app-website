<section id="kontakt" class="bg-primary py-16 md:py-24" aria-labelledby="contact-heading">
  <div class="container-main">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 id="contact-heading" class="mb-4 text-2xl font-bold text-white md:text-3xl">
        Fragen, Feedback oder Kooperationsanfragen?
      </h2>
      <p class="mb-3 text-base text-white/80">
        Schreib uns – wir freuen uns auf deine Nachricht.
      </p>
      <p class="mb-8 text-base text-white/70">
