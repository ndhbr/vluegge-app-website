---
interface Props {
  name: string;
  class?: string;
  size?: number;
}

const { name, class: className = '', size = 24 } = Astro.props;
---

{name === 'shield' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'users' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" />
    <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'heart' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'check' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'home' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'building' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <rect x="4" y="2" width="16" height="20" rx="2" stroke="currentColor" stroke-width="2" />
    <path d="M9 6h2M13 6h2M9 10h2M13 10h2M9 14h2M13 14h2M9 18h6" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}

{name === 'briefcase' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <rect x="2" y="7" width="20" height="14" rx="2" stroke="currentColor" stroke-width="2" />
    <path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
    <path d="M12 12v.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}

{name === 'star' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'search' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="11" cy="11" r="8" stroke="currentColor" stroke-width="2" />
    <path d="M21 21l-4.35-4.35" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}

{name === 'message' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2v10z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}

{name === 'question' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
    <path d="M9 9a3 3 0 015.12 2.13c0 1.5-2.12 2.12-2.12 3.37M12 17h.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
  </svg>
)}

{name === 'verified' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" class={className} aria-hidden="true">
    <path d="M12 2l2.4 3.6H18l.8 3.8L22 12l-3.2 2.6-.8 3.8h-3.6L12 22l-2.4-3.6H6l-.8-3.8L2 12l3.2-2.6L6 5.6h3.6L12 2z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
)}
