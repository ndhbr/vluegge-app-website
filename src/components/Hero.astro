---
import ImageFrame from './ImageFrame.astro';
---

<section class="relative overflow-hidden pt-24 pb-14 md:pt-32 md:pb-20 lg:pt-36 lg:pb-28" aria-labelledby="hero-heading">
  <!-- Background gradient -->
  <div class="absolute inset-0 bg-gradient-to-br from-light-blue via-white to-light-purple/30" aria-hidden="true"></div>
  <div class="absolute top-0 right-0 h-[600px] w-[600px] rounded-full bg-primary/[0.03] blur-3xl" aria-hidden="true"></div>

  <div class="container-main relative">
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Text -->
      <div class="max-w-xl">
        <h1 id="hero-heading" class="hero-animate mb-6 text-4xl font-bold leading-tight text-navy md:text-[48px] md:leading-[60px]">
          Sicher neue Menschen kennenlernen.<br />
          <span class="gradient-text gradient-text-animated">Begleitet statt allein.</span>
        </h1>
        <p class="hero-animate hero-animate-delay-1 mb-8 text-lg leading-relaxed text-text-main md:text-xl">
          vluegge verbindet Menschen mit Unterstützungsbedarf sicher und begleitet – gemeinsam mit Eltern, Betreuern und Einrichtungen.
        </p>

        <!-- Trust badges -->
        <div class="hero-animate hero-animate-delay-2 mb-8 flex flex-wrap gap-3">
          <span class="pulse-on-hover inline-flex items-center gap-2 rounded-full border border-primary/20 bg-light-blue/50 px-3.5 py-2 text-sm font-medium text-navy transition-all duration-200">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="#155DFC" stroke-width="2.5" stroke-linecap="round"/></svg>
            Begleitet durch Guardians
          </span>
          <span class="pulse-on-hover inline-flex items-center gap-2 rounded-full border border-purple/20 bg-light-purple/50 px-3.5 py-2 text-sm font-medium text-navy transition-all duration-200">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.4 3.6H18l.8 3.8L22 12l-3.2 2.6-.8 3.8h-3.6L12 22l-2.4-3.6H6l-.8-3.8L2 12l3.2-2.6L6 5.6h3.6L12 2z" stroke="#9810FA" stroke-width="2.5" stroke-linecap="round"/><path d="M9 12l2 2 4-4" stroke="#9810FA" stroke-width="2.5" stroke-linecap="round"/></svg>
            Verifizierte Nutzer
          </span>
          <span class="pulse-on-hover inline-flex items-center gap-2 rounded-full border border-primary/20 bg-light-blue/50 px-3.5 py-2 text-sm font-medium text-navy transition-all duration-200">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" stroke="#155DFC" stroke-width="2.5" stroke-linecap="round"/></svg>
            Freundschaft, Beziehung & Aktivitäten
          </span>
        </div>

        <!-- CTAs -->
        <div class="hero-animate hero-animate-delay-3 flex flex-wrap gap-4">
          <a href="#app" class="btn-primary">App herunterladen</a>
          <a href="#so-funktionierts" class="btn-secondary">Mehr erfahren</a>
        </div>
      </div>

      <!-- Hero Image -->
      <div class="hero-animate hero-animate-delay-4 relative">
        <ImageFrame
          src="/assets/images/vluegge-app-couple.webp"
          alt="Zwei Menschen mit Unterstützungsbedarf lachen gemeinsam und umarmen sich in einer entspannten Alltagssituation."
          class="aspect-[4/3] w-full shadow-card"
          eager={true}
        />
        <!-- Overlay cards with float animation (hidden on mobile) -->
        <div class="float-slow absolute -left-6 bottom-8 hidden rounded-2xl border border-medium-grey/50 bg-white/95 px-4 py-2.5 shadow-sm backdrop-blur-sm md:block">
          <span class="flex items-center gap-2 text-sm font-semibold text-navy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" stroke="#155DFC" stroke-width="2.5"/></svg>
            Guardian begleitet
          </span>
        </div>
        <div class="float-medium absolute -right-4 top-8 hidden rounded-2xl border border-medium-grey/50 bg-white/95 px-4 py-2.5 shadow-sm backdrop-blur-sm md:block">
          <span class="flex items-center gap-2 text-sm font-semibold text-navy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M9 12l2 2 4-4" stroke="#155DFC" stroke-width="2.5" stroke-linecap="round"/><circle cx="12" cy="12" r="10" stroke="#155DFC" stroke-width="2"/></svg>
            Sicherer Rahmen
          </span>
        </div>
        <div class="float-fast absolute bottom-20 right-4 hidden rounded-2xl border border-medium-grey/50 bg-white/95 px-4 py-2.5 shadow-sm backdrop-blur-sm md:block">
          <span class="flex items-center gap-2 text-sm font-semibold text-navy">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="#9810FA" stroke-width="2" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="#9810FA" stroke-width="2"/></svg>
            Echte Begegnungen
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
